NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://postgres:postgres123@localhost:5433/pasajesgo_db

# Redis
REDIS_URL=redis://localhost:6380

# JWT Auth
JWT_SECRET=super-secret-key-change-me-in-prod
JWT_REFRESH_SECRET=super-refresh-secret-key-change-me
JWT_EXPIRES_IN=15m

# Security
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
TELEMETRY_RATE_LIMIT_PER_MIN=1000

# WebSockets
WS_PORT=3001
